graph TD
    subgraph Client["Client"]
        Browser["REST Client (Browser / Postman)"]
    end

    subgraph App["Application - Node.js with Express"]
        MW["Middleware: Helmet, Rate Limiter, Morgan, JWT Auth"]

        subgraph RC["Routes & Controllers"]
            Login["/api/login - LoginController"]
            Users["/api/users - UserController"]
            Depts["/api/departments - DepartmentController"]
            Roles["/api/jobroles - JobRoleController"]
            Leave["/api/leave-requests - LeaveRequestController"]
            Holidays["/api/public-holidays - PublicHolidayController"]
        end

        subgraph Svc["Services"]
            LoginSvc["LoginService"]
            UserSvc["UserService"]
            DeptSvc["DepartmentService"]
            JobRoleSvc["JobRoleService"]
            LeaveSvc["LeaveRequestService"]
            HolidaySvc["PublicHolidayService"]
        end

        ORM["TypeORM"]
    end

    subgraph DB["Database - MySQL"]
        UsersTable[("users")]
        LeaveTable[("leave_requests")]
        DeptTable[("departments")]
        JobRoleTable[("job_roles")]
        HolidayTable[("public_holiday")]
