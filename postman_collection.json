{
  "info": {
    "name": "Leave Management System",
    "description": "API collection for the Leave Management System assignment. Import this file into Postman and set the `baseUrl` and `token` collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string", "description": "Set after running the Login request" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  pm.test('Token received', () => pm.expect(json.data.token).to.be.a('string'));",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.thompson@company.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login (Manager)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob.mitchell@company.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login (Employee)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"david.okafor@company.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login — Missing fields (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error message present', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error.message).to.include('required');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.thompson@company.com\"\n}"
            }
          }
        },
        {
          "name": "Login — Wrong password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.thompson@company.com\",\n  \"password\": \"WrongPassword\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Leave Requests",
      "item": [
        {
          "name": "Create Leave Request (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Status is Pending', () => pm.expect(json.data.status).to.equal('Pending'));",
                  "pm.test('managerNote is null', () => pm.expect(json.data.managerNote).to.be.null);",
                  "if (json.data.id) pm.collectionVariables.set('leaveRequestId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-04\",\n  \"endDate\": \"2026-08-08\",\n  \"leaveType\": \"Vacation\",\n  \"reason\": \"Summer holiday\"\n}"
            }
          }
        },
        {
          "name": "Create Leave Request — Invalid leaveType (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions leaveType', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error.message).to.include('leaveType');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-04\",\n  \"endDate\": \"2026-08-08\",\n  \"leaveType\": \"Holiday\"\n}"
            }
          }
        },
        {
          "name": "Create Leave Request — No auth (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/leave-requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-04\",\n  \"endDate\": \"2026-08-08\",\n  \"leaveType\": \"Vacation\"\n}"
            }
          }
        },
        {
          "name": "Approve Leave Request (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is Approved', () => pm.expect(json.data.status).to.equal('Approved'));",
                  "pm.test('managerNote stored', () => pm.expect(json.data.managerNote).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests/approve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": 2,\n  \"managerNote\": \"Approved — enjoy your time off!\"\n}"
            }
          }
        },
        {
          "name": "Approve Leave Request — Invalid ID (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests/approve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": \"abc\"\n}"
            }
          }
        },
        {
          "name": "Approve Leave Request — Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests/approve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": 99999\n}"
            }
          }
        },
        {
          "name": "Reject Leave Request (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is Rejected', () => pm.expect(json.data.status).to.equal('Rejected'));",
                  "pm.test('Rejection reason stored', () => pm.expect(json.data.managerNote).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests/reject",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": 6,\n  \"managerNote\": \"Team at capacity during this period.\"\n}"
            }
          }
        },
        {
          "name": "View Leave Status by Employee (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(json.data).to.be.an('array'));",
                  "if (json.data.length > 0) {",
                  "  pm.test('Each item has required fields', () => {",
                  "    const item = json.data[0];",
                  "    pm.expect(item).to.have.property('id');",
                  "    pm.expect(item).to.have.property('startDate');",
                  "    pm.expect(item).to.have.property('endDate');",
                  "    pm.expect(item).to.have.property('status');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leave-requests/status/4"
          }
        },
        {
          "name": "View Leave Status — Employee Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leave-requests/status/99999"
          }
        },
        {
          "name": "View Remaining Leave (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has annualLeaveAllowance', () => pm.expect(json.data).to.have.property('annualLeaveAllowance'));",
                  "pm.test('Has usedDays', () => pm.expect(json.data).to.have.property('usedDays'));",
                  "pm.test('Has remainingDays', () => pm.expect(json.data).to.have.property('remainingDays'));",
                  "pm.test('Remaining = allowance - used', () => {",
                  "  const d = json.data;",
                  "  pm.expect(d.remainingDays).to.equal(d.annualLeaveAllowance - d.usedDays);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leave-requests/remaining/4"
          }
        },
        {
          "name": "View Remaining Leave — Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/leave-requests/remaining/99999"
          }
        },
        {
          "name": "Delete Leave Request (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Success message', () => pm.expect(json.data.message).to.include('deleted'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/leave-requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": 2\n}"
            }
          }
        }
      ]
    }
  ]
}
