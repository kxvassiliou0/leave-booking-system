    {
      "name": "/api/leave-requests",
      "item": [
        {
          "name": "GET /api/leave-requests (Admin - all)",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{jwt_token}}", "type": "string" }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leave-requests",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests"],
              "query": [
                {
                  "key": "employee_id",
                  "value": "4",
                  "disabled": true,
                  "description": "Filter by employee - David Jones"
                },
                {
                  "key": "manager_id",
                  "value": "2",
                  "disabled": true,
                  "description": "Filter by manager's team - Bob Mitchell"
                }
              ]
            },
            "description": "Admin only. Returns all leave requests. Use employee_id or manager_id query param to filter (not both)."
          }
        },
        {
          "name": "POST /api/leave-requests",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{jwt_token}}", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/leave-requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leave_type\": \"Vacation\",\n  \"start_date\": \"2027-09-01\",\n  \"end_date\": \"2027-09-05\"\n}"
            }
          }
        },
        {
          "name": "DELETE /api/leave-requests",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{jwt_token}}", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/leave-requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leave_request_id\": 2\n}",
              "description": "Cancels David Jones's pending sick leave (id 2) - use David's JWT"
            }
          }
        },
        {
          "name": "PATCH /api/leave-requests/approve",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{jwt_token}}", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/leave-requests/approve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leave_request_id\": 6,\n  \"reason\": \"Approved - enjoy your time off!\"\n}",
              "description": "Bob Mitchell (manager id 2) approves Eve Knowles's pending vacation (id 6) - use Manager JWT"
            }
          }
        },
        {
          "name": "PATCH /api/leave-requests/reject",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{jwt_token}}", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/leave-requests/reject",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leave_request_id\": 2,\n  \"reason\": \"Team at capacity during this period.\"\n}",
              "description": "Bob Mitchell (manager id 2) rejects David Jones's pending sick leave (id 2) - use Manager JWT"
            }
          }
        },
        {
