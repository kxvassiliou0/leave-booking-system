{
  "name": "leave-booking-system",
  "author": "Katerina Vassiliou",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "cross-env NODE_ENV=development nodemon --ext ts src/index.ts",
    "seed": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "class-transformer": "^0.5.1",
    "morgan": "^1.10.1",
    "mysql2": "^3.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "class-validator": "^0.15.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "test": "^3.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
