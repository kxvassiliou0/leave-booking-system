erDiagram

    DEPARTMENT {
        int id PK
        string name
    }

    JOB_ROLE {
        int id PK
        string name
    }

    USER {
        int id PK
        string firstName
        string lastName
        string email
        string password
        enum role "Employee | Manager | Admin"
        int annualLeaveAllowance
        int departmentId FK
        int jobRoleId FK
        int managerId FK_NULL
    }

    LEAVE_REQUEST {
        int id PK
        date startDate
        date endDate
        int daysRequested
        enum leaveType "Vacation | Sick | Personal"
        string reason NULL
        enum status DEFAULT_PENDING
        datetime createdAt
        string managerNote NULL
        int userId FK
        int reviewedById FK_NULL
    }

    DEPARTMENT ||--o{ USER : "employs"

    JOB_ROLE ||--o{ USER : "assigned to"

    USER ||--o{ USER : "manages"

    USER ||--o{ LEAVE_REQUEST : "submits"

    USER ||--o{ LEAVE_REQUEST : "reviews"
